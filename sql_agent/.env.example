# Copy to .env and fill in values.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database
# SQLite default (relative path resolved from project root)
DATABASE_URL=sqlite:///sqlite_db/demo.db
# Example Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/mydb

# Memory / storage paths
FAISS_INDEX_DIR=sqlite_db/faiss_index
CHAT_HISTORY_DIR=sqlite_db/chat_histories

# Performance
SCHEMA_CACHE_TTL_SECONDS=300
DATA_FETCH_DEFAULT_LIMIT=100
DATA_FETCH_MAX_LIMIT=10000

# Logging
LOG_LEVEL=INFO

# gRPC gateway (phase 1)
GRPC_PORT=50051

# gRPC TLS (phase 8.5). Both paths must be set to enable TLS; otherwise
# the server binds insecurely. Recommended for production ONLY if a
# service mesh isn't handling mTLS. Paths are resolved relative to the
# CWD of the server process (typically the repo root or /app in Docker).
# GRPC_TLS_CERT_FILE=deploy/tls/server.crt
# GRPC_TLS_KEY_FILE=deploy/tls/server.key

# Bearer-token auth (phase 8.5). Non-empty value enables the interceptor.
# Every RPC must then carry `authorization: Bearer <token>` metadata
# matching this value, EXCEPT for gRPC health checks (probe-safe).
# GRPC_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# LLM serving (phase 2) — defaults preserve original OpenAI behavior.
# ---------------------------------------------------------------------------
# LLM_PROVIDER        : "openai" | "hf" | "mock"
# EMBEDDING_PROVIDER  : "auto" (follows LLM_PROVIDER) | "openai" | "hf" | "mock"
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=auto

# Hardware selection (only one may be true; both false => auto-detect).
FORCE_CPU=false
FORCE_GPU=false

# HuggingFace (used only when LLM_PROVIDER=hf and/or EMBEDDING_PROVIDER=hf).
# Default: Qwen2.5-1.5B-Instruct (~3 GB, CPU-viable). Override for other
# hardware:
#   Qwen/Qwen2.5-3B-Instruct   (~6 GB RAM CPU, better JSON quality)
#   Qwen/Qwen2.5-7B-Instruct   (~14 GB RAM CPU / ~8 GB VRAM GPU, best quality)
#   HuggingFaceTB/SmolLM2-135M-Instruct (~270 MB, tests only — JSON-weak)
HF_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HF_QUANTIZATION options:
#   none            - full precision (default)
#   int8_dynamic    - torch.quantization.quantize_dynamic on CPU Linear
#                     layers. Works on all platforms; ~2x faster, slight
#                     quality drop. Recommended for Windows / CPU-only dev.
#   4bit | 8bit     - bitsandbytes quantization (Linux / WSL only).
HF_QUANTIZATION=none
HF_MAX_NEW_TOKENS=512
# HF_CACHE_DIR=  (empty => default HuggingFace cache location)

# ---------------------------------------------------------------------------
# Routing / A/B testing (phase 3) — opt-in, default disabled.
# ---------------------------------------------------------------------------
LLM_ROUTING_ENABLED=false
# Weighted-random provider choice. Format: "provider:weight, provider:weight"
LLM_ROUTING_WEIGHTS=openai:100
# Append-only JSONL log of routing decisions (relative to project root).
# Kept under logs/ to avoid collisions with the sql_agent/routing/ source package.
LLM_ROUTING_DECISION_LOG=logs/routing/decisions.jsonl

# ---------------------------------------------------------------------------
# ML lifecycle tracking (phase 4) — opt-in, default disabled.
# ---------------------------------------------------------------------------
# TRACKING_BACKEND:
#   auto    : try mlflow; fall back to file; fall back to noop (recommended)
#   mlflow  : MLflow only; raise if not installed
#   file    : JSONL only (requires no extra deps)
#   noop    : disable tracking entirely
TRACKING_ENABLED=false
TRACKING_BACKEND=auto
TRACKING_FILE_LOG=logs/tracking/turns.jsonl

# MLflow-specific. Empty URI => file:<project_root>/logs/tracking/mlruns
# MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=sql_agent

# Truncate user_query stored in tracking params to this length (chars).
TRACKING_QUERY_MAX_CHARS=500

# ---------------------------------------------------------------------------
# Observability (phase 5) — opt-in.
# ---------------------------------------------------------------------------
# LOG_JSON=true emits one-JSON-per-line structured logs that include
# session_id and request_id (threaded via contextvars). Default false keeps
# the human-readable format unchanged.
LOG_JSON=false

# Prometheus metrics exporter. When enabled, boots an HTTP server on
# METRICS_PORT at server start. Requires prometheus_client.
METRICS_ENABLED=false
METRICS_PORT=9090
# METRICS_ADDR=  (empty => bind all interfaces; set "127.0.0.1" for loopback)

# ---------------------------------------------------------------------------
# Containerization (phase 6): auto-seed the demo SQLite DB on gRPC boot.
# Off by default. Docker compose default profile turns this on so a bare
# `docker compose up` gives a working system. Leave false in production.
# ---------------------------------------------------------------------------
SEED_DEMO_ON_BOOT=false

# ---------------------------------------------------------------------------
# Read-only memory mode (phase 7; semantics updated in phase 9).
# When true, this pod won't call record_reward / record_penalty. Useful
# for:
#   * FAISS + multi-replica (avoids pod-local divergence).
#   * Qdrant HPA pods under heavy read load (reduces write contention).
# Single-replica deployments can leave as false.
# ---------------------------------------------------------------------------
READ_ONLY_MEMORY=false

# ---------------------------------------------------------------------------
# Memory store backend (phase 9).
#   faiss  — pod-local files. Zero-deps. Single-replica only in production.
#   qdrant — shared vector DB. Safe for HPA-scaled Deployments.
#   auto   — qdrant iff QDRANT_URL is set, else faiss.
# ---------------------------------------------------------------------------
MEMORY_STORE_BACKEND=faiss

# Qdrant (required only when MEMORY_STORE_BACKEND resolves to qdrant).
# Leave QDRANT_URL empty for embedded / on-disk mode (good for single-node
# prod and dev parity). Set to a real URL for shared/multi-replica setups.
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=sql_agent_
